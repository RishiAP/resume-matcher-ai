# Database
DATABASE_URL=postgresql+psycopg://recruitment:yourpassword@localhost:5432/recruitmentdb

# Storage + CORS
UPLOAD_PATH=/var/www/uploads
ALLOWED_ORIGINS=http://localhost:3000

# Celery + Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_BROKER_CONNECTION_RETRY=true
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true
CELERY_AI_RATE_LIMIT_MAX_RETRIES=3
CELERY_AI_RATE_LIMIT_RETRY_DELAY_SECONDS=300
CELERY_AI_RATE_LIMIT_RETRY_DELAY_MAX_SECONDS=1800

# Adaptive rate limiting handles task spacing automatically
# CELERY_AI_TASK_RATE_LIMIT is no longer used

# Token rate limiting (Grok free tier defaults)
TOKEN_LIMIT_PER_MINUTE=10000
TOKEN_LIMIT_PER_DAY=100000
REQUEST_LIMIT_PER_MINUTE=3
REQUEST_LIMIT_PER_DAY=100

# Toggle between local Ollama and remote API
AI_MODE=local

# Local LLM mode (Ollama)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_LLM_MODEL=llama3.1:8b

# Embedding mode (independent from AI_MODE): local | api
EMBED_MODE=local
EMBED_DIMENSIONS=384

# Local embeddings (Hugging Face)
LOCAL_EMBED_MODEL=all-MiniLM-L6-v2
LOCAL_EMBED_DEVICE=cpu

# API mode (remote LLM)
AI_API_BASE_URL=https://api.groq.com/openai/v1
AI_API_LLM_MODEL=llama-3.3-70b-versatile
AI_API_KEY=your_api_key

# API embeddings (used only when EMBED_MODE=api)
# IMPORTANT: this model must output EMBED_DIMENSIONS vectors
AI_API_EMBED_BASE_URL=http://localhost:11434/v1
AI_API_EMBED_MODEL=nomic-embed-text
AI_API_EMBED_KEY=ollama
